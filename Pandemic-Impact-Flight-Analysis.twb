              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Le premier cas de Covid aux États-Unis à était déclarer le 21 Janvier 2020 et une forte augmentation à au lieu à partir de mi Mars 2020' captured-sheet='Dashboard 3' id='1'>
