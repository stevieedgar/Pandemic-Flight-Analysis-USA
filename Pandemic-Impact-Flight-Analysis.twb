    <dashboard name='Story 2' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='22'>Comment la pandémie COVID-19 a-t-elle influencé les retards de vols aux États-Unis entre janvier et juin 2020 ?</run>
          </formatted-text>
        </title>
