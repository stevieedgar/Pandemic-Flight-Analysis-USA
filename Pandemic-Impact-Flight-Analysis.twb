            <zone h='4425' id='3' type-v2='title' w='99064' x='468' y='885' />
            <zone fixed-size='88' h='9735' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99064' x='468' y='5310' />
